{
  "title": "Spring Boot JVM",
  "uid": "spring-boot-jvm",
  "schemaVersion": 39,
  "refresh": "15s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "HTTP Request Count per 15m by Endpoint",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(http_server_requests_seconds_count{job=~\"order-service|inventory-service\"}[15m])) by (job, uri)",
          "legendFormat": "{{job}} {{uri}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "decimals": 0 }
      }
    },
    {
      "id": 2,
      "title": "HTTP Error Rate (4xx/5xx req/s)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(http_server_requests_seconds_count{job=~\"order-service|inventory-service\",status=~\"4..|5..\"}[15m])) by (job, status)",
          "legendFormat": "{{job}} {{status}}"
        }
      ],
      "fieldConfig": {
      //  "defaults": { "unit": "reqps", "color": { "fixedColor": "red", "mode": "fixed" } }
        "defaults": { "unit": "reqps"}
      }
    },
    {
      "id": 3,
      "title": "JVM Heap Memory Used",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(jvm_memory_used_bytes{job=~\"order-service|inventory-service\",area=\"heap\"}) by (job)",
          "legendFormat": "{{job}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes" }
      }
    },
    {
      "id": 4,
      "title": "Process CPU Usage",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "process_cpu_usage{job=~\"order-service|inventory-service\"}",
          "legendFormat": "{{job}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "min": 0, "max": 1 }
      }
    },
    {
      "id": 5,
      "title": "HTTP Request Count by Endpoint",
      "type": "table",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 10 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sort_desc(sum by (job, method, uri) (http_server_requests_seconds_count{job=~\"order-service|inventory-service\"}))",
          "instant": true,
          "legendFormat": ""
        }
      ],
      "transformations": [
        { "id": "labelsToFields", "options": { "valueLabel": "Count" } },
        {
          "id": "organize",
          "options": {
            "renameByName": { "Value": "Count" },
            "indexByName": { "job": 0, "method": 1, "uri": 2, "Count": 3 }
          }
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "align": "left" } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Count" }, "properties": [{ "id": "custom.width", "value": 80 }] }
        ]
      },
      "options": { "sortBy": [{ "displayName": "Count", "desc": true }] }
    },
    {
      "id": 6,
      "title": "HTTP Error Count by Endpoint (4xx/5xx)",
      "type": "table",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 10 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sort_desc(sum by (job, method, uri, status) (http_server_requests_seconds_count{job=~\"order-service|inventory-service\",status=~\"4..|5..*\"}))",
          "instant": true,
          "legendFormat": ""
        }
      ],
      "transformations": [
        { "id": "labelsToFields", "options": { "valueLabel": "Count" } },
        {
          "id": "organize",
          "options": {
            "renameByName": { "Value": "Count" },
            "indexByName": { "job": 0, "status": 1, "method": 2, "uri": 3, "Count": 4 }
          }
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "align": "left" } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Count" }, "properties": [{ "id": "custom.width", "value": 80 }, { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      },
      "options": { "sortBy": [{ "displayName": "Count", "desc": true }] }
    }
  ]
}
